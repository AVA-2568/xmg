#!/usr/bin/env bash
# shellcheck shell=bash
# coding: utf-8
#
# xmg - XMG 主入口
#
# 说明：
#   - 默认启动实时监控界面
#   - 可通过子命令进入菜单、查看系统摘要、显示版本或帮助
#   - 文件内容应使用 UTF-8 编码保存
#

# 必须在 set -o pipefail 前检查是否为 bash
if [ -z "${BASH_VERSION:-}" ]; then
    echo "错误: 需要使用 bash 运行 xmg" >&2
    exit 1
fi

set -Eeuo pipefail

# XMG_HOME 是 XMG 的统一根目录。
# 默认所有 XMG 管理的文件集中放在 /opt/xmg。
XMG_HOME="${XMG_HOME:-/opt/xmg}"
# 主程序目录和模块目录
XMG_BIN_DIR="${XMG_BIN_DIR:-$XMG_HOME/bin}"
XMG_LIB_DIR="${XMG_LIB_DIR:-$XMG_HOME/lib}"
# 导出路径变量，确保被加载的 lib/*.sh 模块使用同一套目录
export XMG_HOME XMG_BIN_DIR XMG_LIB_DIR

if [ ! -d "$XMG_LIB_DIR" ]; then
    echo "错误: XMG lib directory not found: $XMG_LIB_DIR" >&2
    echo "源码目录运行示例: XMG_LIB_DIR=./lib ./xmg" >&2
    exit 1
fi

xmg_require_core_file() {
    local f="$1"

    if [ ! -r "$XMG_LIB_DIR/$f" ]; then
        echo "错误: 缺少核心模块: $XMG_LIB_DIR/$f" >&2
        exit 1
    fi
}

# 入口层只检查自己直接依赖的核心模块
xmg_require_core_file common.sh
xmg_require_core_file system.sh
xmg_require_core_file menu.sh
xmg_require_core_file monitor.sh

# shellcheck source=/usr/local/lib/xmg/common.sh
source "$XMG_LIB_DIR/common.sh"
xmg_color_init

# shellcheck source=/usr/local/lib/xmg/system.sh
source "$XMG_LIB_DIR/system.sh"

# shellcheck source=/usr/local/lib/xmg/menu.sh
source "$XMG_LIB_DIR/menu.sh"

# shellcheck source=/usr/local/lib/xmg/monitor.sh
source "$XMG_LIB_DIR/monitor.sh"

xmg_usage() {
    cat <<EOF
XMG $XMG_VERSION

用法:
  xmg                 启动 XMG Monitor (Real-Time)
  xmg monitor         启动 XMG Monitor (Real-Time)
  xmg menu            进入管理菜单
  xmg doctor          输出轻量系统摘要
  xmg version         显示版本
  xmg help            显示帮助

按键:
  m                   进入管理菜单
  q                   退出

环境变量:
  XMG_LIB_DIR          库目录，默认 /usr/local/lib/xmg
  XMG_CACHE_TTL        基础系统状态缓存秒数，默认 3
  XMG_SERVICE_TTL      服务状态缓存秒数，默认 5
  XMG_MONITOR_INTERVAL UI 刷新间隔，默认 3
  XMG_COLOR            auto/always/never，默认 auto
  XMG_XRAY_SERVICE     Xray 服务名，默认 xray
  XMG_CADDY_SERVICE    Caddy 服务名，默认 caddy
EOF
}

xmg_main() {
    case "${1:-monitor}" in
        monitor)
            xmg_monitor_loop
            ;;
        menu)
            xmg_menu_loop
            ;;
        doctor)
            xmg_system_refresh_all force
            xmg_system_print_summary
            ;;
        version|-v|--version)
            echo "XMG $XMG_VERSION"
            ;;
        help|-h|--help)
            xmg_usage
            ;;
        *)
            xmg_error "未知参数: $1"
            echo
            xmg_usage
            exit 2
            ;;
    esac
}

xmg_main "$@"
